{
  "name": "novapay-platform",
  "version": "2.4.1",
  "description": "NovaPay payment processing platform",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test:unit": "jest --config jest.unit.config.ts",
    "test:integration": "jest --config jest.integration.config.ts",
    "test:smoke": "jest --config jest.smoke.config.ts",
    "lint": "eslint src/ --max-warnings=0",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "simulate": "bash simulate.sh"
  },
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
